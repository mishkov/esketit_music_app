  "version": "0.2.0",
  "configurations": [
    {
      "name": "esketit_music_app",
      "request": "launch",
      "type": "dart",
      "preLaunchTask": "Generate launch defines",
      "flutterMode": "debug",
      "args": ["--web-port=8081"],
      "toolArgs": [
        "--dart-define-from-file=.vscode/launch_defines.json"
      ]
    },
    {
      "name": "esketit_music_app (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "esketit_music_app (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    }
  ]
}
